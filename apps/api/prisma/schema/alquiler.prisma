// Alquiler. Pertenece a una propiedad. Tiene sus propios socios con %.
// Al crear, socios se pre-llenan con los de la sociedad; Mariana puede editarlos.
// `numero` es incremental (secuencia arranca en 1000 en migración).
model Alquiler {
  id                 String         @id @default(cuid())
  numero             Int            @unique @default(autoincrement())
  propiedadId        String
  inquilinoId        String
  monto              BigInt
  moneda             Moneda
  fechaInicio        DateTime       @db.Date
  fechaFin           DateTime?      @db.Date
  status             AlquilerStatus @default(ACTIVO)
  finalizadoEn       DateTime?      @db.Date
  motivoFinalizacion String?
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  propiedad   Propiedad       @relation(fields: [propiedadId], references: [id])
  inquilino   Cuenta          @relation("AlquilerInquilino", fields: [inquilinoId], references: [id])
  socios      AlquilerSocio[]
  movimientos Movimiento[]

  @@index([status])
  @@index([fechaInicio])
  @@index([inquilinoId])
  @@index([propiedadId])
  @@index([numero])
}

enum AlquilerStatus {
  ACTIVO
  FINALIZADO
}

enum Moneda {
  ARS
  USD
}

// Socios del alquiler con %. Suma percentBps == 10000.
model AlquilerSocio {
  id         String   @id @default(cuid())
  alquilerId String
  cuentaId   String
  percentBps Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  alquiler Alquiler @relation(fields: [alquilerId], references: [id], onDelete: Cascade)
  cuenta   Cuenta   @relation(fields: [cuentaId], references: [id])

  @@unique([alquilerId, cuentaId])
  @@index([alquilerId])
  @@index([cuentaId])
}
