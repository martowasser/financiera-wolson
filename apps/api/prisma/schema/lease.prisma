model Lease {
  id                 String       @id @default(cuid())
  propertyId         String
  tenantId           String
  currency           Currency
  baseAmount         BigInt
  managedBy          LeaseManager @default(DIRECT)
  thirdPartyEntityId String?
  startDate          DateTime     @db.Date
  endDate            DateTime?    @db.Date
  isActive           Boolean      @default(true)
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  property     Property     @relation(fields: [propertyId], references: [id])
  tenant       Entity       @relation("LeaseTenant", fields: [tenantId], references: [id])
  thirdParty   Entity?      @relation("LeaseThirdParty", fields: [thirdPartyEntityId], references: [id])
  invoices     Invoice[]
  priceHistory LeasePrice[]

  @@index([propertyId])
  @@index([tenantId])
  @@index([isActive])
}

model LeasePrice {
  id         String    @id @default(cuid())
  leaseId    String
  amount     BigInt
  validFrom  DateTime  @db.Date
  validUntil DateTime? @db.Date
  createdAt  DateTime  @default(now())

  lease Lease @relation(fields: [leaseId], references: [id])

  @@index([leaseId])
  @@index([leaseId, validFrom])
}

enum LeaseManager {
  DIRECT
  THIRD_PARTY
}
