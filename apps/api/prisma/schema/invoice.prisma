model Invoice {
  id          String        @id @default(cuid())
  leaseId     String
  code        String        @unique
  periodMonth Int
  periodYear  Int
  baseAmount  BigInt
  vatAmount   BigInt        @default(0)
  totalAmount BigInt
  netAmount   BigInt
  status      InvoiceStatus @default(PENDING)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lease        Lease              @relation(fields: [leaseId], references: [id])
  transactions Transaction[]
  retentions   InvoiceRetention[]

  @@index([leaseId])
  @@index([status])
  @@index([periodYear, periodMonth])
}

model InvoiceRetention {
  id        String   @id @default(cuid())
  invoiceId String
  concept   String
  amount    BigInt
  notes     String?
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([concept])
}

enum InvoiceStatus {
  PENDING
  PAID
  PARTIAL
  CANCELLED
}
