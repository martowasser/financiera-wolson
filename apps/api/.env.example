# Postgres connection. Local docker default abajo; en Render se inyecta del DB managed.
DATABASE_URL="postgresql://financiero:financiero_dev@localhost:5434/financiero?schema=public"

# Secret usado para firmar JWTs de access y refresh. En Render se genera automático.
JWT_SECRET="dev-jwt-secret-change-in-production"

# Server.
PORT=3001
NODE_ENV=development

# Origen permitido para CORS. Lista separada por coma si hay varios.
# En Render, setealo a la URL de Vercel (ej. https://tu-app.vercel.app).
CORS_ORIGIN="http://localhost:3000"
